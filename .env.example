# Copy this file to .env.local for local dev (gitignored).
# In Vercel, set these in Project → Settings → Environment Variables.
#
# DO NOT put real secrets in this file — it is tracked by git.

# ---- Supabase ----------------------------------------------------------
# From Supabase → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# SERVER ONLY — never expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Email (Resend) ----------------------------------------------------
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=re_...

# Verified sender — must match a domain you've verified in Resend.
# During development you can use Resend's test sender: onboarding@resend.dev
FROM_EMAIL=hello@thubtentravels.com

# Where enquiry notifications are sent.
ADMIN_EMAIL=hello@thubtentravels.com

# ---- Admin login -------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# Any long random string. Rotating this signs every active admin out.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string
